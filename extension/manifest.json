{
  "manifest_version": 3,
  "name": "Wishlisted",
  "version": "0.1.9",
  "description": "Save products from any shop into a clean visual wishlist.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' http: https: data:"
  },
  "action": {
    "default_title": "Wishlisted",
    "default_icon": {
      "16": "icons/wishlisted-cart-16.png",
      "32": "icons/wishlisted-cart-32.png",
      "48": "icons/wishlisted-cart-48.png",
      "128": "icons/wishlisted-cart-128.png"
    }
  },
  "icons": {
    "16": "icons/wishlisted-cart-16.png",
    "32": "icons/wishlisted-cart-32.png",
    "48": "icons/wishlisted-cart-48.png",
    "128": "icons/wishlisted-cart-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "content/constants.js",
        "content/lifecycle.js",
        "content/panel/render.js",
        "content/panel/events.js",
        "content/panel/items.js",
        "content/icons.js",
        "content/extractors/main.js",
        "content/extractors/jsonld.js",
        "content/extractors/dom.js",
        "content/extractors/embedded.js",
        "content/extractors/enrich.js",
        "content/extractors/context.js",
        "content/storage.js",
        "content/overlays.js",
        "content/styles/panel-1.js",
        "content/styles/panel-2.js",
        "content/styles/panel-3.js",
        "content/styles/panel-4.js",
        "content/styles/panel-5.js",
        "content/styles/panel.js",
        "content/styles/overlay.js",
        "content/pricing/dom.js",
        "content/storage-settings.js",
        "content/pricing/parse.js",
        "content/pricing/rates.js",
        "content/media.js",
        "content/text.js",
        "content/utils.js",
        "content/bootstrap.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/onest.ttf"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
