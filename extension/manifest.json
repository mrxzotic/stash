{
  "manifest_version": 3,
  "name": "Stash",
  "version": "0.1.154",
  "description": "Save products from any shop into a compact local stash.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' http: https: data:"
  },
  "action": {
    "default_title": "Stash",
    "default_icon": {
      "16": "icons/stash-cart-16.png",
      "32": "icons/stash-cart-32.png",
      "48": "icons/stash-cart-48.png",
      "128": "icons/stash-cart-128.png"
    }
  },
  "icons": {
    "16": "icons/stash-cart-16.png",
    "32": "icons/stash-cart-32.png",
    "48": "icons/stash-cart-48.png",
    "128": "icons/stash-cart-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/alex-kornev.png",
        "assets/source-aimeleondore.png"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
