{
  "manifest_version": 3,
  "name": "Stashed",
  "version": "0.1.324",
  "description": "Save products from any shop into a compact local stash.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' http: https: data:"
  },
  "action": {
    "default_title": "Stashed",
    "default_icon": {
      "16": "icons/stashed-lock-16.png",
      "32": "icons/stashed-lock-32.png",
      "48": "icons/stashed-lock-48.png",
      "128": "icons/stashed-lock-128.png"
    }
  },
  "commands": {
    "save-to-stashed": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Save current page to Stashed"
    },
    "toggle-stashed": {
      "suggested_key": {
        "default": "Alt+Shift+O",
        "mac": "Alt+Shift+O"
      },
      "description": "Open or close Stashed"
    }
  },
  "icons": {
    "16": "icons/stashed-lock-16.png",
    "32": "icons/stashed-lock-32.png",
    "48": "icons/stashed-lock-48.png",
    "128": "icons/stashed-lock-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/alex-kornev.png",
        "icons/stashed-lock-48.png",
        "icons/stashed-lock-greyscale-128.png",
        "assets/source-aimeleondore.png",
        "assets/phosphor-light/*.svg",
        "fonts/inter-latin-var.woff2",
        "fonts/ibm-plex-mono-latin-400.woff2",
        "fonts/ibm-plex-mono-latin-600.woff2",
        "fonts/ibm-plex-mono-latin-700.woff2"
      ],
      "matches": ["http://*/*", "https://*/*"],
      "use_dynamic_url": true
    }
  ]
}
