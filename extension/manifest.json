{
  "manifest_version": 3,
  "name": "Tuckio",
  "version": "0.1.460",
  "description": "Save products from any shop into a compact local library.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' http: https: data:"
  },
  "action": {
    "default_title": "Tuckio",
    "default_icon": {
      "16": "icons/tuckio-icon-16.png",
      "32": "icons/tuckio-icon-32.png",
      "48": "icons/tuckio-icon-48.png",
      "128": "icons/tuckio-icon-128.png"
    }
  },
  "commands": {
    "save-to-tuckio": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Save current page to Tuckio"
    },
    "toggle-tuckio": {
      "suggested_key": {
        "default": "Alt+Shift+O",
        "mac": "Alt+Shift+O"
      },
      "description": "Open or close Tuckio"
    }
  },
  "icons": {
    "16": "icons/tuckio-icon-16.png",
    "32": "icons/tuckio-icon-32.png",
    "48": "icons/tuckio-icon-48.png",
    "128": "icons/tuckio-icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/alex-kornev.png",
        "assets/tuckio-app.png",
        "assets/tuckio-app-open.png",
        "assets/tuckio-app-black.png",
        "assets/tuckio-app-white.png",
        "icons/tuckio-icon-48.png",
        "icons/tuckio-icon-black-128.png",
        "icons/tuckio-icon-white-128.png",
        "assets/source-aimeleondore.png",
        "assets/phosphor-light/*.svg",
        "fonts/*.woff2"
      ],
      "matches": ["http://*/*", "https://*/*"],
      "use_dynamic_url": true
    }
  ]
}
